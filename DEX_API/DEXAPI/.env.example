# Copy to .env locally. In Railway, set these as project/service variables.
# Do not commit .env or put real keys in this file.
#
# Backend <-> frontend link: This file does NOT control the frontend. The frontend
# uses its own config (dex.ts) for swap router/factory. These vars only affect
# the DEX API endpoints /V2/pairs, /V2/allPairs (pair/volume data). Leave factory
# and info_getter as 0x0 if you don't need that; AI agent and other APIs still work.

PORT=3000
OPENAI_API_KEY=your_openai_api_key_here

ENABLE_DOCS_BOOT=false

BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com

# Optional: only needed if you want /V2/pairs and /V2/allPairs to return pair data.
# Frontend swap uses router/factory from frontend config, not from here.
BSC_TESTNET_FACTORY=0x0000000000000000000000000000000000000000
BSC_TESTNET_INFO_GETTER=0x0000000000000000000000000000000000000000
SEPOLIA_FACTORY=0x0000000000000000000000000000000000000000
SEPOLIA_INFO_GETTER=0x0000000000000000000000000000000000000000
ETHEREUM_FACTORY=0x0000000000000000000000000000000000000000
ETHEREUM_INFO_GETTER=0x0000000000000000000000000000000000000000

NFT_MARKET_ADDRESS=0x0000000000000000000000000000000000000000
NFT_CHAIN_RPC_URL=https://data-seed-prebsc-1-s1.bnbchain.org:8545

UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

PKEY=

BSC_TESTNET_GAME_TOKEN=
BSC_TESTNET_GAME_ROUTER=
BSC_TESTNET_GAME_MARSHOT=
BSC_TESTNET_GAME_RPC=https://data-seed-prebsc-1-s1.bnbchain.org:8545
SEPOLIA_GAME_TOKEN=
SEPOLIA_GAME_ROUTER=
SEPOLIA_GAME_MARSHOT=
SEPOLIA_GAME_RPC=https://ethereum-sepolia-rpc.publicnode.com
ETHEREUM_GAME_TOKEN=
ETHEREUM_GAME_ROUTER=
ETHEREUM_GAME_MARSHOT=
ETHEREUM_GAME_RPC=https://ethereum-rpc.publicnode.com
